// Schéma Prisma pour EVENTIA (MVP)

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Organisateur (administrateur)
model Organizer {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  avatarUrl String?
  securityAlerts Boolean @default(true)
  failedLoginCount Int @default(0)
  lockUntil DateTime?
  language String @default("fr")
  timezone String @default("Africa/Kinshasa")
  dateFormat String @default("DD/MM/YYYY")
  emailNotifications Boolean @default(true)
  messageNotifications Boolean @default(true)
  eventAlerts Boolean @default(true)
  marketingNotifications Boolean @default(false)
  defaultEventType String @default("mariage")
  defaultEventTime String @default("18:00")
  defaultQrEnabled Boolean @default(true)
  role String @default("user")
  companyName String?
  jobTitle  String?
  addressLine1 String?
  addressLine2 String?
  city      String?
  postalCode String?
  country   String?
  website   String?
  bio       String?
  dateOfBirth DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
  coHostedEvents EventCoOrganizer[] @relation("EventCoHostOrganizer")
  invitationsSent EventCoOrganizer[] @relation("EventCoHostInviter")
  coOrganizerInvitesSent EventCoOrganizerInvite[] @relation("EventCoHostInviteInviter")
  coOrganizerInvitesAccepted EventCoOrganizerInvite[] @relation("EventCoHostInviteAcceptor")
  payments Payment[]
  subscriptions OrganizerSubscription[]
  logins OrganizerLogin[]
}

model OrganizerLogin {
  id          Int      @id @default(autoincrement())
  organizer   Organizer? @relation(fields: [organizerId], references: [id])
  organizerId Int?
  ip          String?
  userAgent   String?
  success     Boolean
  createdAt   DateTime @default(now())

  @@index([organizerId, createdAt])
}

// Événement géré dans l’application
model Event {
  id               Int       @id @default(autoincrement())
  name             String
  type             String
  dateTime         DateTime
  location         String
  address          String?
  details          String? @db.Text
  program          String? @db.Text
  invitationMessage String? @db.Text
  coverImageUrl    String?
  hostNames        String?
  seatingMode      SeatingMode @default(TABLE)
  logoUrl          String?
  themePreset      String?
  primaryColor     String?
  accentColor      String?
  fontFamily       String?
  animationStyle   String?
  drinksEnabled    Boolean   @default(true)
  guestbookRequiresApproval Boolean @default(false)
  tableCount       Int
  capacityPerTable Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organizer   Organizer @relation(fields: [organizerId], references: [id])
  organizerId Int

  tables   Table[]
  guests   Guest[]
  drinks   DrinkOption[]
  gifts    GiftItem[]
  memories EventMemory[]
  chatMessages EventChatMessage[]
  quickReplies EventQuickReply[]
  messages GuestBookMessage[]
  programItems EventProgramItem[]
  coOrganizers EventCoOrganizer[]
  coOrganizerInvites EventCoOrganizerInvite[]
  tableLayouts TableLayout[]
  activeTableLayoutId Int? @unique
  activeTableLayout TableLayout? @relation("EventActiveLayout", fields: [activeTableLayoutId], references: [id])
  payments Payment[]
  paidPlanCode String?
  paidAt DateTime?
}

model EventProgramItem {
  id          Int      @id @default(autoincrement())
  timeLabel   String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int

  @@index([eventId, order])
}

model Payment {
  id        Int      @id @default(autoincrement())
  organizer Organizer @relation(fields: [organizerId], references: [id])
  organizerId Int
  event     Event?   @relation(fields: [eventId], references: [id])
  eventId   Int?
  planCode  String
  planType  PaymentPlanType
  amount    Int
  currency  String
  provider  String
  method    String?
  status    PaymentStatus @default(PENDING)
  txRef     String   @unique
  providerRef String?
  paymentLink String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizerSubscription {
  id          Int      @id @default(autoincrement())
  organizer   Organizer @relation(fields: [organizerId], references: [id])
  organizerId Int
  planCode    String
  status      SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PaymentPlanType {
  EVENT
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

model EventCoOrganizer {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())

  event       Event     @relation(fields: [eventId], references: [id])
  eventId     Int

  organizer   Organizer @relation("EventCoHostOrganizer", fields: [organizerId], references: [id])
  organizerId Int

  invitedBy   Organizer @relation("EventCoHostInviter", fields: [invitedById], references: [id])
  invitedById Int

  @@unique([eventId, organizerId])
}

model EventCoOrganizerInvite {
  id          Int      @id @default(autoincrement())
  email       String
  token       String   @unique
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?

  event       Event     @relation(fields: [eventId], references: [id])
  eventId     Int

  invitedBy   Organizer @relation("EventCoHostInviteInviter", fields: [invitedById], references: [id])
  invitedById Int

  acceptedBy   Organizer? @relation("EventCoHostInviteAcceptor", fields: [acceptedById], references: [id])
  acceptedById Int?

  @@unique([eventId, email])
}

// Table physique à l’événement
model Table {
  id        Int     @id @default(autoincrement())
  label     String
  capacity  Int
  location  String?
  positionX Float?
  positionY Float?
  event     Event   @relation(fields: [eventId], references: [id])
  eventId   Int

  guests Guest[]
  layoutPositions TableLayoutPosition[]
}

model TableLayout {
  id        Int      @id @default(autoincrement())
  name      String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions TableLayoutPosition[]
  activeForEvent Event? @relation("EventActiveLayout")

  @@unique([eventId, name])
}

model TableLayoutPosition {
  id        Int      @id @default(autoincrement())
  layout    TableLayout @relation(fields: [layoutId], references: [id])
  layoutId  Int
  table     Table    @relation(fields: [tableId], references: [id])
  tableId   Int
  positionX Float
  positionY Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([layoutId, tableId])
}

// Invité
model Guest {
  id         Int        @id @default(autoincrement())
  fullName   String
  lastName   String?
  middleName String?
  firstName  String?
  phone      String?
  email      String?
  sex        Sex?
  category   String?
  guestType  GuestType?
  status     GuestStatus @default(PENDING)
  plusOneCount Int      @default(0)
  allergies  String?
  mealPreference String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int

  table   Table? @relation(fields: [tableId], references: [id])
  tableId Int?

  invitation GuestInvitation?
  choices    GuestDrinkChoice[]
  messages   GuestBookMessage[]
  chatMessages EventChatMessage[]
}

// Invitation numérique (token + QR code)
model GuestInvitation {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  pdfUrl     String?
  createdAt  DateTime @default(now())
  sentAt     DateTime?
  openedAt   DateTime?
  openCount  Int      @default(0)
  respondedAt DateTime?
  checkedInAt DateTime?
  checkInCount Int     @default(0)

  guest   Guest @relation(fields: [guestId], references: [id])
  guestId Int   @unique
}

// Options de boissons pour un événement
model DrinkOption {
  id        Int         @id @default(autoincrement())
  name      String
  category  DrinkType
  availableQuantity Int?
  maxPerGuest Int?
  event     Event       @relation(fields: [eventId], references: [id])
  eventId   Int

  choices GuestDrinkChoice[]
}

// Choix de boissons d’un invité
model GuestDrinkChoice {
  id           Int          @id @default(autoincrement())
  quantity     Int          @default(1)

  guest        Guest        @relation(fields: [guestId], references: [id])
  guestId      Int

  drinkOption  DrinkOption  @relation(fields: [drinkOptionId], references: [id])
  drinkOptionId Int
}

// Livre d’or
model GuestBookMessage {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
  isHidden  Boolean  @default(false)

  guest   Guest? @relation(fields: [guestId], references: [id])
  guestId Int?

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int
}

model GiftItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  url         String
  isCashFund  Boolean  @default(false)
  createdAt   DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int
}

model EventMemory {
  id               Int      @id @default(autoincrement())
  mediaType        MemoryType
  mediaUrl         String
  caption          String?
  uploadedByName   String?
  createdAt        DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int
}

model EventChatMessage {
  id         Int       @id @default(autoincrement())
  senderType ChatSenderType
  senderName String
  message    String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int

  guest   Guest? @relation(fields: [guestId], references: [id])
  guestId Int?
}

model EventQuickReply {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  event   Event @relation(fields: [eventId], references: [id])
  eventId Int
}

enum GuestStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum Sex {
  M
  F
}

enum GuestType {
  COUPLE
  MR
  MME
  MLLE
}

enum DrinkType {
  ALCOHOLIC
  SOFT
}

enum MemoryType {
  IMAGE
  VIDEO
}

enum ChatSenderType {
  HOST
  GUEST
}

enum SeatingMode {
  TABLE
  ZONE
  NONE
}

